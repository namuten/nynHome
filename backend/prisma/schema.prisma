generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  nickname     String
  avatarUrl    String?
  role         Role     @default(user)
  createdAt    DateTime @default(now())

  comments      Comment[]
  pushSubs      PushSubscription[]

  @@map("users")
}

enum Role {
  admin
  user
}

model Post {
  id           Int      @id @default(autoincrement())
  title        String
  body         String   @db.Text
  category     Category
  thumbnailUrl String?
  isPublished  Boolean  @default(false)
  viewCount    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  media    Media[]
  comments Comment[]

  @@map("posts")
}

enum Category {
  creative
  blog
  study
}

model Media {
  id           Int          @id @default(autoincrement())
  postId       Int?
  fileUrl      String
  mimeType     String
  fileCategory FileCategory
  fileName     String
  fileSize     BigInt
  duration     Int?
  width        Int?
  height       Int?
  createdAt    DateTime     @default(now())

  post        Post?             @relation(fields: [postId], references: [id], onDelete: SetNull)
  derivatives MediaDerivative[]

  @@map("media")
}


enum FileCategory {
  image
  video
  audio
  document
  other
}

model MediaTypeConfig {
  id           Int     @id @default(autoincrement())
  mimeType     String  @unique
  fileCategory String
  maxSizeMb    Int
  isAllowed    Boolean @default(true)

  @@map("media_type_config")
}

model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  body      String   @db.Text
  reply     String?  @db.Text
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Schedule {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  startAt     DateTime
  endAt       DateTime
  color       String   @default("#6844c7")
  createdAt   DateTime @default(now())

  @@map("schedules")
}

model ContentLayout {
  id         Int      @id @default(autoincrement())
  sectionKey String
  postIds    Json
  order      Int
  isVisible  Boolean  @default(true)
  updatedAt  DateTime @updatedAt

  @@map("content_layout")
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int?
  endpoint  String   @unique @db.VarChar(512)
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("push_subscriptions")
}

model ProfileSettings {
  id             Int      @id @default(autoincrement())
  locale         String   @unique
  displayName    String
  tagline        String?
  bio            String?  @db.Text
  avatarUrl      String?
  coverImageUrl  String?
  school         String?
  location       String?
  emailPublic    String?
  socialLinks    Json?    // 예: { "github": "...", "instagram": "..." }
  interests      Json?    // 예: ["웹개발", "디자인"]
  skills         Json?    // 예: ["React", "TypeScript", "Node.js"]
  achievements   Json?    // 예: [{"title": "우수상", "date": "2026-01-01"}]
  updatedAt      DateTime @updatedAt

  @@map("profile_settings")
}

model PortfolioSection {
  id         Int      @id @default(autoincrement())
  locale     String   // "ko" | "en"
  sectionKey String   // 예: "education", "experience"
  title      String
  body       String?  @db.Text
  items      Json?    // 예: [{"title": "...", "subtitle": "...", "date": "...", "desc": "..."}]
  order      Int      @default(0)
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("portfolio_sections")
}

model ShowcaseItem {
  id           Int       @id @default(autoincrement())
  title        String
  slug         String    @unique
  description  String?   @db.Text
  category     String    // 예: "3D Graphics", "Full-Stack Web"
  coverMediaId Int?
  mediaIds     Json?     // 예: [1, 2, 3]
  postId       Int?      // 관련 블로그 포스트 ID
  locale       String    @default("ko") // "ko" | "en"
  tags         Json?     // 예: ["React", "WebGL"]
  isFeatured   Boolean   @default(false)
  isPublished  Boolean   @default(false)
  publishedAt  DateTime?
  order        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("showcase_items")
}

model SeoSettings {
  id          Int      @id @default(autoincrement())
  routeKey    String   // 예: "home", "portfolio", "blog", "study"
  locale      String   // "ko" | "en"
  title       String
  description String?  @db.Text
  ogImageUrl  String?
  keywords    Json?    // 예: ["React", "WebGL"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([routeKey, locale])
  @@map("seo_settings")
}

model AuditLog {
  id               Int      @id @default(autoincrement())
  action           String   @db.VarChar(120)
  resourceType     String   @db.VarChar(80) @map("resource_type")
  resourceId       String?  @db.VarChar(120) @map("resource_id")
  adminUserId      Int?     @map("admin_user_id")
  summary          String   @db.VarChar(300)
  metadata         Json?
  ipHash           String?  @db.VarChar(128) @map("ip_hash")
  userAgentSummary String?  @db.VarChar(200) @map("user_agent_summary")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model AnalyticsEvent {
  id            BigInt   @id @default(autoincrement())
  eventName     String   @db.VarChar(120) @map("event_name")
  route         String   @db.VarChar(300)
  referrer      String?  @db.VarChar(500)
  locale        String?  @db.VarChar(5)
  userId        Int?     @map("user_id")
  sessionIdHash String?  @db.VarChar(128) @map("session_id_hash")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("analytics_events")
}

model DailyAnalyticsRollup {
  id             Int      @id @default(autoincrement())
  day            DateTime @db.Date
  route          String?  @db.VarChar(300)
  eventName      String   @db.VarChar(120) @map("event_name")
  count          Int
  uniqueSessions Int      @map("unique_sessions")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("daily_analytics_rollups")
}

model MediaDerivative {
  id             Int      @id @default(autoincrement())
  mediaId        Int      @map("media_id")
  derivativeType String   @db.VarChar(80) @map("derivative_type")
  fileUrl        String   @db.VarChar(500) @map("file_url")
  width          Int?
  height         Int?
  mimeType       String   @db.VarChar(120) @map("mime_type")
  fileSize       BigInt   @map("file_size")
  createdAt      DateTime @default(now()) @map("created_at")

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, derivativeType])
  @@map("media_derivatives")
}

model BackupRun {
  id           Int       @id @default(autoincrement())
  backupType   String    @db.VarChar(80) @map("backup_type")
  status       String    @db.VarChar(40)
  fileUrl      String?   @db.VarChar(500) @map("file_url")
  checksum     String?   @db.VarChar(128)
  sizeBytes    BigInt?   @map("size_bytes")
  startedAt    DateTime  @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  errorMessage String?   @db.Text @map("error_message")

  @@map("backup_runs")
}
